// Algoritmo que determine si una persona es mayor de edad
Algoritmo Act1_Lecc7_Inc2
	Definir edad Como Entero
	Escribir 'Ingrese su edad'
	Leer edad
	// Evaluo si es mayor o no
	Si edad>=18 Entonces
		Escribir 'Usted es mayor de edad'
	SiNo
		Escribir 'Usted no es mayor de edad'
	FinSi
FinAlgoritmo
